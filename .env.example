# Application
APP_TITLE=RAG_API
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=rag_api_db
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Full DB URLs
DATABASE_URL=postgresql+psycopg2://postgres:your_password_here@db:5432/rag_api_db
TEST_DATABASE_URL=postgresql+psycopg2://postgres:your_password_here@db:5432/rag_api_test_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
TASKS_CACHE_TTL=60